---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Forgot password | ardmore.directory"
  description="Reset your ardmore.directory account password."
>
  <div class="max-w-sm mx-auto py-16 px-4">
    <div class="mb-8 text-center">
      <a href="/login" class="text-sm text-base-500 hover:text-base-900 transition-colors">&larr; Back to log in</a>
    </div>

    <h1 class="text-2xl font-medium text-base-900 mb-1 text-center">Forgot your password?</h1>
    <p class="text-sm text-base-500 text-center mb-8">Enter your email and we'll send you a reset link</p>

    <form id="forgot-form" novalidate class="flex flex-col gap-4">
      <div class="flex flex-col gap-1.5">
        <label for="email" class="text-sm font-medium text-base-800">Email address</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          placeholder="you@example.com"
          class="rounded-lg border border-base-300 px-3 py-2 text-sm text-base-900 placeholder:text-base-400 focus:outline-none focus:ring-2 focus:ring-base-900" />
      </div>

      <div id="forgot-error" class="hidden rounded-lg bg-red-50 border border-red-200 px-3 py-2 text-sm text-red-700" role="alert"></div>
      <div id="forgot-success" class="hidden rounded-lg bg-green-50 border border-green-200 px-3 py-2 text-sm text-green-800" role="status"></div>

      <button type="submit" id="forgot-btn"
        class="w-full py-2.5 bg-brand-orange text-white text-sm font-medium rounded-full hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed">
        Send reset link
      </button>
    </form>
  </div>
</BaseLayout>

<script>
  const form       = document.getElementById('forgot-form')    as HTMLFormElement;
  const btn        = document.getElementById('forgot-btn')     as HTMLButtonElement;
  const errorEl    = document.getElementById('forgot-error')   as HTMLElement;
  const successEl  = document.getElementById('forgot-success') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Sending…';

    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();

    const res = await fetch('/api/auth/forget-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, redirectTo: `${window.location.origin}/reset-password` }),
    });

    if (!res.ok) {
      const j = await res.json().catch(() => ({})) as { message?: string };
      errorEl.textContent = j.message ?? 'Something went wrong. Please try again.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send reset link';
    } else {
      successEl.textContent = "If that email has an account, you'll receive a reset link shortly.";
      successEl.classList.remove('hidden');
      form.reset();
      btn.disabled = false;
      btn.textContent = 'Send reset link';
    }
  });
</script>
