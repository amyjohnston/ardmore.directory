---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reset password | ardmore.directory"
  description="Choose a new password for your ardmore.directory account."
>
  <div class="max-w-sm mx-auto py-16 px-4">
    <h1 class="text-2xl font-medium text-base-900 mb-1 text-center">Choose a new password</h1>
    <p class="text-sm text-base-500 text-center mb-8">Enter your new password below</p>

    <form id="reset-form" novalidate class="flex flex-col gap-4">
      <div class="flex flex-col gap-1.5">
        <label for="password" class="text-sm font-medium text-base-800">New password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password"
          placeholder="••••••••" minlength="8"
          class="rounded-lg border border-base-300 px-3 py-2 text-sm text-base-900 placeholder:text-base-400 focus:outline-none focus:ring-2 focus:ring-base-900" />
        <p class="text-xs text-base-400">At least 8 characters</p>
      </div>

      <div id="reset-error" class="hidden rounded-lg bg-red-50 border border-red-200 px-3 py-2 text-sm text-red-700" role="alert"></div>

      <button type="submit" id="reset-btn"
        class="w-full py-2.5 bg-brand-orange text-white text-sm font-medium rounded-full hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed">
        Set new password
      </button>
    </form>
  </div>
</BaseLayout>

<script>
  import { authClient } from '../lib/auth-client';

  const form    = document.getElementById('reset-form')  as HTMLFormElement;
  const btn     = document.getElementById('reset-btn')   as HTMLButtonElement;
  const errorEl = document.getElementById('reset-error') as HTMLElement;

  // Extract token from URL query string (?token=...)
  const token = new URLSearchParams(window.location.search).get('token');
  if (!token) {
    errorEl.textContent = 'Invalid or expired reset link. Please request a new one.';
    errorEl.classList.remove('hidden');
    btn.disabled = true;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!token) return;
    errorEl.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Saving…';

    const newPassword = (form.querySelector('#password') as HTMLInputElement).value;
    if (newPassword.length < 8) {
      errorEl.textContent = 'Password must be at least 8 characters.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Set new password';
      return;
    }

    const { error } = await authClient.resetPassword({ newPassword, token });

    if (error) {
      errorEl.textContent = error.message ?? 'Reset failed. The link may have expired.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Set new password';
    } else {
      window.location.href = '/login?reset=success';
    }
  });
</script>
