---
import { businesses, categories } from "@/data/businesses.js";

const accentColors = [
  "rgba(255, 185, 0, 0.7)",
  "rgb(255, 131, 0)",
  "rgba(57, 113, 102, 0.7)",
  "rgba(194, 196, 0, 0.7)",
];
---

<section class="py-8 lg:py-12">
  <div class="flex flex-col gap-6 lg:flex-row lg:gap-8 lg:items-start">

    <!-- Filter: horizontal scroll pills on mobile, sticky sidebar on desktop -->
    <aside aria-labelledby="filter-heading">
      <p id="filter-heading" class="text-xs font-semibold uppercase tracking-widest text-base-500 mb-3">Filter by type</p>
      <ul class="flex flex-row gap-2 overflow-x-auto pb-1 lg:flex-col lg:gap-1 lg:overflow-visible lg:pb-0 lg:w-52 lg:sticky lg:top-8">
        <li class="shrink-0">
          <button
            class="filter-btn whitespace-nowrap lg:w-full lg:text-left px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-base-900 text-white"
            data-filter="all"
            aria-pressed="true"
          >
            All businesses
          </button>
        </li>
        {categories.map((cat) => (
          <li class="shrink-0">
            <button
              class="filter-btn whitespace-nowrap lg:w-full lg:text-left px-3 py-2 rounded-lg text-sm font-medium transition-colors text-base-700 hover:bg-base-100"
              data-filter={cat}
              aria-pressed="false"
            >
              {cat}
            </button>
          </li>
        ))}
      </ul>
    </aside>

    <!-- Business cards grid -->
    <div id="biz-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3 flex-1">
      {
        businesses.map((biz, i) => (
          <div
            class="biz-card bg-white rounded-2xl shadow-sm overflow-hidden border-t-4 flex flex-col"
            style={`border-top-color: ${accentColors[i % 4]}`}
            data-category={biz.category}
          >
            <div class="w-full aspect-video bg-base-100 flex items-center justify-center">
              <span class="text-sm font-medium text-base-400">Your logo here</span>
            </div>
            <div class="p-5 flex flex-col gap-3 flex-1">
              <div class="flex flex-col gap-1">
                <span class="text-xs font-medium text-base-400 uppercase tracking-wide">{biz.category}</span>
                <h3 class="font-semibold text-base-900 text-lg leading-tight">{biz.name}</h3>
              </div>
              <ul class="flex flex-col gap-2 text-sm text-base-600">
                {biz.phone && (
                  <li class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0 text-base-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                    </svg>
                    <span class="flex-1">{biz.phone}</span>
                    <div class="relative group">
                      <button
                        class="copy-phone size-6 flex items-center justify-center rounded text-base-400 hover:text-base-700 hover:bg-base-100 transition-colors"
                        data-phone={biz.phone}
                        aria-label="Copy phone number"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="copy-icon size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2" />
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" class="check-icon size-3.5 hidden text-brand-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </button>
                      <span class="tooltip-label pointer-events-none absolute bottom-full right-0 mb-1.5 whitespace-nowrap rounded px-2 py-1 text-xs bg-base-900 text-white opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity">
                        Click to copy
                      </span>
                    </div>
                  </li>
                )}
                {biz.email && (
                  <li class="flex items-start gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mt-0.5 shrink-0 text-base-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                    </svg>
                    <a href={`mailto:${biz.email}`} class="hover:text-base-900 transition-colors truncate">{biz.email}</a>
                  </li>
                )}
                {biz.address && (
                  <li class="flex items-start gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mt-0.5 shrink-0 text-base-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    <a
                      href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(biz.address)}`}
                      target="_blank"
                      rel="noopener"
                      class="hover:text-base-900 transition-colors"
                    >{biz.address}</a>
                  </li>
                )}
                {biz.website && (
                  <li class="flex items-start gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mt-0.5 shrink-0 text-base-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3 12c0 .778.099 1.533.284 2.253" />
                    </svg>
                    <a href={biz.website} target="_blank" rel="noopener" class="hover:text-base-900 transition-colors truncate">
                      {biz.website.replace(/^https?:\/\//, "")}
                    </a>
                  </li>
                )}
                {biz.facebook && (
                  <li class="flex items-start gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4 mt-0.5 shrink-0 text-base-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                    <a href={biz.facebook} target="_blank" rel="noopener" class="hover:text-base-900 transition-colors">
                      Facebook
                    </a>
                  </li>
                )}
              </ul>
            </div>
          </div>
        ))
      }

      <!-- Empty state -->
      <p id="no-results" class="hidden col-span-full text-center text-base-500 py-16 text-sm">
        No businesses found in this category yet.
      </p>
    </div>

  </div>
</section>

<!-- Screen reader announcements for copy action -->
<div aria-live="polite" aria-atomic="true" class="sr-only" id="copy-announce"></div>

<script>
  // Category filter
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".biz-card");
  const noResults = document.getElementById("no-results")!;

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      // Update active button styles and aria-pressed
      buttons.forEach((b) => {
        b.classList.remove("bg-base-900", "text-white");
        b.classList.add("text-base-700", "hover:bg-base-100");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("bg-base-900", "text-white");
      btn.classList.remove("text-base-700", "hover:bg-base-100");
      btn.setAttribute("aria-pressed", "true");

      // Show/hide cards
      let visible = 0;
      cards.forEach((card) => {
        const match = filter === "all" || card.dataset.category === filter;
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });

      noResults.classList.toggle("hidden", visible > 0);
    });
  });

  // Phone copy buttons
  const copyAnnounce = document.getElementById("copy-announce")!;

  document.querySelectorAll<HTMLButtonElement>(".copy-phone").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const phone = btn.dataset.phone!;
      await navigator.clipboard.writeText(phone);

      const tooltip = btn.parentElement!.querySelector<HTMLElement>(".tooltip-label")!;
      const copyIcon = btn.querySelector<SVGElement>(".copy-icon")!;
      const checkIcon = btn.querySelector<SVGElement>(".check-icon")!;

      tooltip.textContent = "Copied!";
      copyIcon.classList.add("hidden");
      checkIcon.classList.remove("hidden");
      copyAnnounce.textContent = `${phone} copied to clipboard.`;

      setTimeout(() => {
        tooltip.textContent = "Click to copy";
        copyIcon.classList.remove("hidden");
        checkIcon.classList.add("hidden");
        copyAnnounce.textContent = "";
      }, 2000);
    });
  });
</script>
