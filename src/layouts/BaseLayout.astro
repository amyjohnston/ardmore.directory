---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Directory for Ardmore, Oklahoma | ardmore.directory",
  description = "The free local business directory for Ardmore, Oklahoma. Find restaurants, shops, services, automotive, real estate, and more in your community.",
} = Astro.props;
---

<html lang="en">
  <head>
    <!-- CookieYes — must be first script in <head> to intercept all others -->
    <!-- Start cookieyes banner -->
    <script is:inline id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/848da2d5fe89e3be885227d9a1b9282e/script.js"></script>
    <!-- End cookieyes banner -->
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-86WJKMHM4G"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Set default consent state before any tracking fires.
      // CookieYes will update these when the user makes a choice.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });

      gtag('js', new Date());
      gtag('config', 'G-86WJKMHM4G');
    </script>
    <BaseHead title={title} description={description} />
    <slot name="head" />
  </head>
  <body class="bg-white max-w-6xl mx-auto px-8 lg:px-12 flex flex-col min-h-screen">
    <a href="#biz-grid" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-base-900 focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Skip to listings
    </a>

    <!-- Site nav -->
    <nav class="flex items-center justify-between py-4 border-b border-base-100" aria-label="Site navigation">
      <a href="/" class="text-sm font-semibold text-base-700 tracking-wide hover:text-base-900 transition-colors">
        ardmore.directory
      </a>
      <div class="flex items-center gap-3 text-sm">
        <!-- Logged-out state (shown by default, hidden by JS when session exists) -->
        <div id="nav-loggedout" class="flex items-center gap-3">
          <a href="/login" class="text-base-600 hover:text-base-900 transition-colors font-medium">Log in</a>
          <a href="/register" class="px-3 py-1.5 bg-brand-orange text-white rounded-full font-medium hover:opacity-90 transition-opacity">Register</a>
        </div>
        <!-- Logged-in state (hidden by default, shown by JS when session exists) -->
        <div id="nav-loggedin" class="hidden flex items-center gap-3">
          <a href="/dashboard" class="text-base-600 hover:text-base-900 transition-colors font-medium">My listing</a>
          <button id="nav-signout" class="px-3 py-1.5 bg-base-100 text-base-700 rounded-full font-medium hover:bg-base-200 transition-colors">Sign out</button>
        </div>
      </div>
    </nav>

    <main class="grow"><slot /></main>
    <Footer />
  </body>
</html>

<script>
  import { authClient } from '../lib/auth-client';

  const loggedOut = document.getElementById('nav-loggedout')!;
  const loggedIn  = document.getElementById('nav-loggedin')!;
  const signOutBtn = document.getElementById('nav-signout')!;

  // Check session and show the right nav state
  authClient.getSession().then(({ data }) => {
    if (data?.session) {
      loggedOut.classList.add('hidden');
      loggedIn.classList.remove('hidden');
    }
  });

  signOutBtn.addEventListener('click', async () => {
    await authClient.signOut();
    window.location.href = '/';
  });
</script>
