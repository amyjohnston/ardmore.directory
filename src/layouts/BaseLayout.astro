---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/global/Footer.astro";
---

<html lang="en">
  <head>
    <BaseHead />
  </head>
  <body class="bg-white max-w-6xl mx-auto px-8 lg:px-12 flex flex-col">
    <a href="#biz-grid" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-base-900 focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Skip to listings
